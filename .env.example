# ═══════════════════════════════════════════════════
#  نور القدس ERP — .env.example
#  انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل
# ═══════════════════════════════════════════════════

APP_NAME="نور القدس"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Cairo
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_EG

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────
# production: warning | staging: info | local: debug
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database (PostgreSQL) ────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nour_al_quds
DB_USERNAME=postgres
DB_PASSWORD=

# ── Session ──────────────────────────────────────
# 30 minutes per security policy (CLAUDE.md)
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache / Queue ─────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=nour_quds_

# ── Mail ─────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_ADDRESS="نور القدس"

# ── Backup (spatie/laravel-backup) ────────────────
# اتركه فارغاً لو ما تريدش تشفير النسخ الاحتياطية
BACKUP_ARCHIVE_PASSWORD=

# ── AWS (اختياري — للنسخ الاحتياطية السحابية) ────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
